# API 认证令牌（留空禁用认证）
API_TOKEN=

# 数据库配置
DATABASE_URL=sqlite:./data/vibe-repo/db/vibe-repo.db?mode=rwc
DATABASE_MAX_CONNECTIONS=10

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Webhook 配置
WEBHOOK_DOMAIN=http://localhost:3000
# IMPORTANT: Set a strong secret key for production (generate with: openssl rand -hex 32)
WEBHOOK_SECRET_KEY=
WEBHOOK_BOT_USERNAME=vibe-repo-bot

# WebSocket 配置
# WebSocket 认证令牌（留空禁用认证，不推荐用于生产环境）
# 生成方法: openssl rand -hex 32
WEBSOCKET_AUTH_TOKEN=

# 日志配置
RUST_LOG=debug
